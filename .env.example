# OpenAI API key (required for AI agents)
OPENAI_API_KEY=sk-...

# Data directory (default: ~/.memora)
MEMORA_DATA_DIR=~/.memora

# Log level (DEBUG, INFO, WARNING, ERROR)
MEMORA_LOG_LEVEL=INFO

# Auto-approve confidence threshold (0.0 - 1.0)
MEMORA_AUTO_APPROVE_THRESHOLD=0.85

# Embedding model (default: all-mpnet-base-v2)
MEMORA_EMBEDDING_MODEL=all-mpnet-base-v2

# API host/port
MEMORA_API_HOST=0.0.0.0
MEMORA_API_PORT=8000
